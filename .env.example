# Nexus — environment variables (example)
# Copy this file to `.env` and fill in real values. `.env` is git-ignored.
#
# Development note: the frontend currently runs on MOCK DATA and does NOT need a
# database. You only need DATABASE_URL if you intend to run Prisma migrations or
# the seed script (npm run db:seed). `npm run dev` works without it.

# PostgreSQL connection string used by Prisma (prisma/schema.prisma).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nexus?schema=public"

# Auth.js / NextAuth v5 session-signing secret (Sprint 1 Auth).
# Required to sign in. Generate one with:  openssl rand -base64 32
# (or: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
AUTH_SECRET="replace-with-a-32-byte-base64-secret"

# ─── Frontend API integration (foundation) ──────────────────────────────────────
# Data source for the frontend. "mock" = the in-memory mock store (current, default);
# "api" = the real backend APIs. Keep "mock" until pages are integrated one endpoint
# at a time. NEXT_PUBLIC_* vars are exposed to the browser bundle.
NEXT_PUBLIC_DATA_SOURCE="mock"

# Base URL the API client prepends to request paths. Empty = same-origin (recommended
# — the app and API share an origin). Set only for a cross-origin backend, e.g.
# "https://api.example.com".
NEXT_PUBLIC_API_BASE_URL=""
