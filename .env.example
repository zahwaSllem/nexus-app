# Nexus — environment variables (example)
# Copy this file to `.env` and fill in real values. `.env` is git-ignored.
#
# Development note: the frontend currently runs on MOCK DATA and does NOT need a
# database. You only need DATABASE_URL if you intend to run Prisma migrations or
# the seed script (npm run db:seed). `npm run dev` works without it.

# PostgreSQL connection string used by Prisma (prisma/schema.prisma).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nexus?schema=public"
